# ---- Namespace ----
apiVersion: v1
kind: Namespace
metadata:
  name: jerney
  labels:
    app.kubernetes.io/part-of: jerney

---
# ---- Database Secret ----
# In production, use External Secrets Operator or Sealed Secrets.
# This is base64 encoded for demo purposes.
# echo -n 'jerney_user' | base64 → amVybmV5X3VzZXI=
# echo -n 'jerney_pass_2026' | base64 → amVybmV5X3Bhc3NfMjAyNg==
# echo -n 'jerney_db' | base64 → amVybmV5X2Ri

apiVersion: v1
kind: Secret
metadata:
  name: jerney-db-secret
  namespace: jerney
  labels:
    app.kubernetes.io/part-of: jerney
type: Opaque
data:
  POSTGRES_USER: amVybmV5X3VzZXI=
  POSTGRES_PASSWORD: amVybmV5X3Bhc3NfMjAyNg==
  POSTGRES_DB: amVybmV5X2Ri

---
# ---- EBS StorageClass (gp3) ----
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: jerney-ebs-sc
provisioner: ebs.csi.eks.amazonaws.com
parameters:
  type: gp3
  encrypted: "true"
reclaimPolicy: Retain
volumeBindingMode: WaitForFirstConsumer
allowVolumeExpansion: true

---
# ---- PersistentVolumeClaim for PostgreSQL (EBS) ----
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: jerney-db-pvc
  namespace: jerney
  labels:
    app.kubernetes.io/part-of: jerney
    app.kubernetes.io/component: database
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: jerney-ebs-sc
  resources:
    requests:
      storage: 10Gi
