name: bankapp-devsecops-pipeline
on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]
jobs:
  compile_project:
    name: compile
    runs-on: ubuntu-latest
    
    defaults:
      run:
        working-directory: bankapp

    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: "17"
          distribution: "temurin"
          cache: maven

      - name: Build with Maven (compile only)
        run: mvn -B compile

  test_project:
    name: unit_tests
    runs-on: ubuntu-latest
    needs: compile_project

    defaults:
      run:
        working-directory: bankapp

    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: "17"
          distribution: "temurin"
          cache: maven

      - name: Execute Unit Tests
        run: mvn -B test

  build_project:
    name: build_project
    runs-on: ubuntu-latest
    needs: test_project

    defaults:
      run:
        working-directory: bankapp

    steps:
      - uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: "17"
          distribution: "temurin"
          cache: maven

      - name: Package JAR
        run: mvn -B package

